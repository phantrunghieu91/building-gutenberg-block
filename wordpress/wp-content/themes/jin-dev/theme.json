{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "75rem",
      "wideSize": "87.5rem"
    },
		"spacing": {
			"blockGap": true,
			"padding": true,
			"margin": true,
			"spacingScale": {
				"operator": "*",
				"increment": 0.5,
				"step": 10,
				"mediumStep": 1.5,
				"unit": "rem"
			},
			"spacingSizes": [],
			"units": ["px", "rem", "em", "ch", "%", "vh", "vw"]
		}
  },
	"styles": {},
	"customTemplates": {},
	"templateParts": {},
	"patterns": []
}